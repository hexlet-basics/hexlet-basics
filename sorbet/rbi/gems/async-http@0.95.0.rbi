  #
  # pkg:gem/async-http#lib/async/http/statistics.rb:29
  def wrap(response, &block); end

  class << self
    # Start tracking statistics from the current time.
    #
    # pkg:gem/async-http#lib/async/http/statistics.rb:16
    def start; end
  end
end

