  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/server.rb:56
  def each(task: T.unsafe(nil)); end

  # Returns the value of attribute requests.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/server.rb:32
  def requests; end
end

# An HTTP/2 stream that manages headers, input data, and output data for a single request/response exchange.
#
# pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:18
class Async::HTTP::Protocol::HTTP2::Stream < ::Protocol::HTTP2::Stream
  # Initialize the stream state.
  #
  # @return [Stream] a new instance of Stream
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:20
  def initialize(*_arg0); end

  # Add a header to the stream, validating against HTTP/2 constraints.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:44
  def add_header(key, value, trailer: T.unsafe(nil)); end

  # When the stream transitions to the closed state, this method is called. There are roughly two ways this can happen:
  # - A frame is received which causes this stream to enter the closed state. This method will be invoked from the background reader task.
  # - A frame is sent which causes this stream to enter the closed state. This method will be invoked from that task.
  # While the input stream is relatively straight forward, the output stream can trigger the second case above
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:176
  def closed(error); end

  # Called when the output terminates normally.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:142
  def finish_output(error = T.unsafe(nil)); end

  # Returns the value of attribute headers.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:35
  def headers; end

  # Sets the attribute headers
  #
  # @param value the value to set the attribute headers to.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:35
  def headers=(_arg0); end

  # Returns the value of attribute input.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:39
  def input; end

  # Returns the value of attribute pool.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:37
  def pool; end

  # Sets the attribute pool
  #
  # @param value the value to set the attribute pool to.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:37
  def pool=(_arg0); end

  # Prepare the input stream which will be used for incoming data frames.
  #
  # @return [Input] the input body.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:94
  def prepare_input(length); end

  # Process an incoming DATA frame and write it to the input body.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:114
  def process_data(frame); end

  # Process an incoming HEADERS frame, dispatching to initial or trailing header handling.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:67
  def process_headers(frame); end

  # Process trailing headers received after the body.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:59
  def receive_trailing_headers(headers, end_stream); end

  # Set the body and begin sending it.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:135
  def send_body(body, trailer = T.unsafe(nil)); end

  # Update the local flow control window after receiving data.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:104
  def update_local_window(frame); end

  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:88
  def wait_for_input; end

  # Called when the flow control window is updated.
  #
  # pkg:gem/async-http#lib/async/http/protocol/http2/stream.rb:164
  def window_updated(size); end
end

# pkg:gem/async-http#lib/async/http/protocol/http2/connection.rb:27
Async::HTTP::Protocol::HTTP2::TRAILER = T.let(T.unsafe(nil), String)

# pkg:gem/async-http#lib/async/http/protocol/http2.rb:21
Async::HTTP::Protocol::HTTP2::VERSION = T.let(T.unsafe(nil), String)

