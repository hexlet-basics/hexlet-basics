# Runs multiple tool calls concurrently with Ruby's built-in threads or optional fibers.
#
# pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:5
module RubyLLM::ToolConcurrency
  private

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:83
  def capture_result(index, tool_call, rails_executor, execute); end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:64
  def collect_results(queue, count, on_result:); end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:11
  def modes; end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:98
  def rails_executor; end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:19
  def run(mode, tool_calls, on_result: T.unsafe(nil), &_arg3); end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:90
  def run_tool_call(tool_call, rails_executor, execute); end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:42
  def run_with_fibers(tool_calls, on_result:, &execute); end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:28
  def run_with_threads(tool_calls, on_result:, &execute); end

  # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:15
  def supported?(name); end

  class << self
    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:11
    def modes; end

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:19
    def run(mode, tool_calls, on_result: T.unsafe(nil), &_arg3); end

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:15
    def supported?(name); end

    private

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:83
    def capture_result(index, tool_call, rails_executor, execute); end

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:64
    def collect_results(queue, count, on_result:); end

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:98
    def rails_executor; end

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:90
    def run_tool_call(tool_call, rails_executor, execute); end

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:42
    def run_with_fibers(tool_calls, on_result:, &execute); end

    # pkg:gem/ruby_llm#lib/ruby_llm/tool_concurrency.rb:28
    def run_with_threads(tool_calls, on_result:, &execute); end
  end
end

