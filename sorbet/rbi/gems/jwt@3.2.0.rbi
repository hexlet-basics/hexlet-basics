# https://tools.ietf.org/html/rfc7517
#
# pkg:gem/jwt#lib/jwt/jwk/set.rb:9
class JWT::JWK::Set
  include ::Enumerable
  extend ::Forwardable

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:15
  def initialize(jwks = T.unsafe(nil), options = T.unsafe(nil)); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:78
