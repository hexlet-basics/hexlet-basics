  # pkg:gem/jwt#lib/jwt/jwk/set.rb:37
  def dig(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:37
  def each(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:73
  def eql?(other); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:33
  def export(options = T.unsafe(nil)); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:74
  def filter!(&block); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:13
  def keys; end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:75
  def length(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:55
  def merge(enum); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:45
  def reject!(&block); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:39
  def select!(&block); end

  # pkg:gem/jwt#lib/jwt/jwk/set.rb:37
