# This class checks missing presence validator
#
# pkg:gem/database_consistency#lib/database_consistency/checkers/column_checkers/null_constraint_checker.rb:6
class DatabaseConsistency::Checkers::NullConstraintChecker < ::DatabaseConsistency::Checkers::ColumnChecker
  private

  # pkg:gem/database_consistency#lib/database_consistency/checkers/column_checkers/null_constraint_checker.rb:90
  def belongs_to_association; end

  # Table of possible statuses
  #
  # We consider PresenceValidation, InclusionValidation, ExclusionValidation, NumericalityValidator with nil,
  # or required BelongsTo association using this column
  #
  # pkg:gem/database_consistency#lib/database_consistency/checkers/column_checkers/null_constraint_checker.rb:32
  def check; end

  # pkg:gem/database_consistency#lib/database_consistency/checkers/column_checkers/null_constraint_checker.rb:68
