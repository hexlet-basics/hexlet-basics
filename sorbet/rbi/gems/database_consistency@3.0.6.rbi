  # pkg:gem/database_consistency#lib/database_consistency/checkers/column_checkers/null_constraint_checker.rb:76
  def numericality_validator_without_allow_nil?; end

  # We skip check when:
  #  - column hasn't null constraint
  #  - column has default value
