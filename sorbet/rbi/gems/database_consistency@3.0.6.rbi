  def source_location; end

  # pkg:gem/database_consistency#lib/database_consistency/checkers/column_checkers/missing_index_find_by_checker.rb:17
  def to_h; end

  # pkg:gem/database_consistency#lib/database_consistency/checkers/column_checkers/missing_index_find_by_checker.rb:17
  def total_findings_count; end
end

