  # pkg:gem/omniauth#lib/omniauth.rb:181
  def camelize(word, first_letter_in_uppercase = T.unsafe(nil)); end

  # pkg:gem/omniauth#lib/omniauth.rb:166
  def deep_merge(hash, other_hash); end

  # pkg:gem/omniauth#lib/omniauth.rb:162
  def form_css; end

  class << self
    # pkg:gem/omniauth#lib/omniauth.rb:181
    def camelize(word, first_letter_in_uppercase = T.unsafe(nil)); end

    # pkg:gem/omniauth#lib/omniauth.rb:166
    def deep_merge(hash, other_hash); end

    # pkg:gem/omniauth#lib/omniauth.rb:162
    def form_css; end
  end
end
