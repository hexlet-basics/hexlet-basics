# pkg:gem/annotaterb#lib/annotate_rb/model_annotator/column_annotation/default_value_builder.rb:6
class AnnotateRb::ModelAnnotator::ColumnAnnotation::DefaultValueBuilder
  # pkg:gem/annotaterb#lib/annotate_rb/model_annotator/column_annotation/default_value_builder.rb:7
  def initialize(value, options); end

  # @return [String]
  # Returns the value to get written to file by file.puts. Strings get written to file so escaped quoted strings
  # get written as quoted. For example, if `value: "\"some_string\""` then "some_string" gets written.
  # Same with arrays, if `value: "[\"a\", \"b\", \"c\"]"` then `["a", "b", "c"]` gets written.
  #
  # @example "\"some_string\""
  # @example "NULL"
  # @example "1.2"
  #
  # pkg:gem/annotaterb#lib/annotate_rb/model_annotator/column_annotation/default_value_builder.rb:20
  def build; end

  private

  # pkg:gem/annotaterb#lib/annotate_rb/model_annotator/column_annotation/default_value_builder.rb:30
  def quote(value); end

  # pkg:gem/annotaterb#lib/annotate_rb/model_annotator/column_annotation/default_value_builder.rb:46
  def quote_array(value); end
end

