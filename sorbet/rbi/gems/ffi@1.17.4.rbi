  # pkg:gem/ffi#lib/ffi.rb:3
  def autorelease?; end

  # pkg:gem/ffi#lib/ffi.rb:3
  def call(*_arg0); end

  # pkg:gem/ffi#lib/ffi.rb:3
  def free; end

  # Retrieve Array of parameter types
  #
  # This method returns an Array of FFI types accepted as function parameters.
  #
  # @return [Array<FFI::Type>]
  #
  # pkg:gem/ffi#lib/ffi/function.rb:49
  def param_types; end

  # Retrieve the return type of the function
  #
  # This method returns FFI type returned by the function.
  #
  # @return [FFI::Type]
  #
  # pkg:gem/ffi#lib/ffi/function.rb:40
  def return_type; end

  private

  # pkg:gem/ffi#lib/ffi.rb:3
  def initialize_copy(_arg0); end

  # pkg:gem/ffi#lib/ffi.rb:3
  def type; end
end

