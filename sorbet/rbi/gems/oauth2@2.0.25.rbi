  # @param [Hash, nil] params additional query parameters
  # @return [String] the constructed revoke URL
  #
  # pkg:gem/oauth2#lib/oauth2/client.rb:120
  def revoke_url(params = T.unsafe(nil)); end

  # pkg:gem/oauth2#lib/oauth2/client.rb:26
  def secret; end

  # pkg:gem/oauth2#lib/oauth2/client.rb:26
  def site; end

  # Set the site host
