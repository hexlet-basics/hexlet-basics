# pkg:gem/flipper#lib/flipper/instrumentation/log_subscriber.rb:8
class Flipper::Instrumentation::LogSubscriber < ::ActiveSupport::LogSubscriber
  # Logs an adapter operation. If operation is for a feature, then that
  # feature is included in log output.
  #
  # Example Output
  #
  #   # log output for adapter operation with feature
  #   # Flipper feature(search) adapter(memory) enable  (0.0ms)  [ result=...]
  #
  #   # log output for adapter operation with no feature
  #   # Flipper adapter(memory) features (0.0ms)  [ result=... ]
  #
  # Returns nothing.
  #
  # pkg:gem/flipper#lib/flipper/instrumentation/log_subscriber.rb:51
  def adapter_operation(event); end

  # Logs a feature operation.
  #
  # Example Output
  #
  #   flipper[:search].enabled?(user)
  #   # Flipper feature(search) enabled? false (1.2ms)  [ actors=... ]
  #
  # Returns nothing.
  #
  # pkg:gem/flipper#lib/flipper/instrumentation/log_subscriber.rb:17
  def feature_operation(event); end

  # pkg:gem/flipper#lib/flipper/instrumentation/log_subscriber.rb:70
  def logger; end

  private

  # pkg:gem/flipper#lib/flipper/instrumentation/log_subscriber.rb:93
  def color_name(name); end

  class << self
    # pkg:gem/flipper#lib/flipper/instrumentation/log_subscriber.rb:74
    def attach; end

    # pkg:gem/flipper#lib/flipper/instrumentation/log_subscriber.rb:78
    def detach; end
  end
end

