#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

# NOTE: миграции гоняет одноразовый Helm pre-upgrade Job (k8s/app-chart/templates/migrate.job.yaml),
# а не каждый под на старте — иначе реплики дерутся за advisory-lock (ConcurrentMigrationError).

exec "${@}"
