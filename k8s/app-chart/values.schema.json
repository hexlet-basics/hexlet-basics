{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "codebasics values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "slackNotification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nginxImageRepository": {
      "type": "string",
      "minLength": 1
    },
    "appImageRepository": {
      "type": "string",
      "minLength": 1
    },
    "gatewayClassName": {
      "type": "string",
      "minLength": 1
    },
    "gatewayAddressType": {
      "type": "string",
      "minLength": 1
    },
    "gatewayAddressValue": {
      "type": "string",
      "minLength": 1
    },
    "gatewaySubnetIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gatewayCertificateId": {
      "type": "string",
      "minLength": 1
    },
    "primaryHost": {
      "type": "string",
      "minLength": 1
    },
    "wildcardHost": {
      "type": "string",
      "minLength": 1
    },
    "secondaryHost": {
      "type": "string",
      "minLength": 1
    },
    "gatewayBackendUseHttp2": {
      "type": "boolean"
    },
    "gatewayBackendUpgradeType": {
      "type": "string",
      "minLength": 1
    },
    "webAutoscalingEnabled": {
      "type": "boolean"
    },
    "webAutoscalingMinReplicas": {
      "type": "integer",
      "minimum": 1
    },
    "webAutoscalingMaxReplicas": {
      "type": "integer",
      "minimum": 1
    },
    "webAutoscalingTargetCpuUtilizationPercentage": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "webAutoscalingTargetMemoryUtilizationPercentage": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100
    },
    "networkPolicyEnabled": {
      "type": "boolean"
    },
    "dockerConfig": {
      "type": "string"
    },
    "appEnv": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "required": [
    "version",
    "nginxImageRepository",
    "appImageRepository",
    "gatewayClassName",
    "gatewayAddressType",
    "gatewayAddressValue",
    "gatewaySubnetIds",
    "gatewayCertificateId",
    "primaryHost",
    "wildcardHost",
    "secondaryHost",
    "gatewayBackendUseHttp2",
    "gatewayBackendUpgradeType",
    "webAutoscalingEnabled",
    "webAutoscalingMinReplicas",
    "webAutoscalingMaxReplicas",
    "webAutoscalingTargetCpuUtilizationPercentage",
    "webAutoscalingTargetMemoryUtilizationPercentage",
    "networkPolicyEnabled",
    "dockerConfig",
    "appEnv"
  ]
}
